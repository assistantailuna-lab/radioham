---
interface Props {
	title: string;
	pdfPath: string;
}

const { title, pdfPath } = Astro.props;
---

<div class="pdf-inline-viewer" data-pdf-viewer data-pdf-path={pdfPath}>
	<div class="pdf-toolbar">
		<strong>{title}</strong>
		<div class="pdf-toolbar-actions">
			<button type="button" data-action="prev">Önceki</button>
			<span data-role="status">Yukleniyor...</span>
			<button type="button" data-action="next">Sonraki</button>
			<button type="button" data-action="first">İlk Sayfa</button>
			<label class="page-jump">
				Sayfa
				<input type="number" min="1" step="1" inputmode="numeric" data-role="page-input" />
			</label>
			<button type="button" data-action="goto">Git</button>
			<button type="button" data-action="answer">Cevap Anahtarı Aç</button>
		</div>
	</div>

	<div class="pdf-canvas-wrap">
		<canvas data-role="canvas"></canvas>
	</div>

	<p class="pdf-note">
		
	</p>

	<div class="answer-modal" data-role="answer-modal" hidden>
		<div class="answer-modal-dialog" role="dialog" aria-modal="true" aria-label="Cevap Anahtari">
			<div class="answer-modal-header">
				<strong>Cevap Anahtari (Son Sayfa)</strong>
				<button type="button" data-action="answer-close" aria-label="Kapat">Kapat</button>
			</div>
			<div class="answer-canvas-wrap">
				<canvas data-role="answer-canvas"></canvas>
			</div>
			<p class="answer-status" data-role="answer-status">Hazirlaniyor...</p>
		</div>
	</div>
</div>

<style>
	.pdf-inline-viewer {
		border: 1px solid #d7e2ee;
		border-radius: 10px;
		background: #f8fbff;
		padding: 12px;
	}

	.pdf-toolbar {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		align-items: center;
		justify-content: space-between;
	}

	.pdf-toolbar strong {
		font: 700 15px/1.2 "Exo 2", sans-serif;
		color: #123b6c;
	}

	.pdf-toolbar-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		align-items: center;
	}

	.pdf-toolbar button {
		border: 1px solid #bfd9f5;
		background: #fff;
		color: #114b86;
		border-radius: 8px;
		padding: 7px 10px;
		font: 700 12px/1 "Exo 2", sans-serif;
		cursor: pointer;
	}

	.pdf-toolbar button:hover {
		background: #eef6ff;
	}

	.pdf-toolbar button:disabled {
		cursor: not-allowed;
		opacity: 0.55;
	}

	.pdf-toolbar [data-role="status"] {
		font: 600 12px/1 "Barlow", sans-serif;
		color: #3f5f84;
		padding: 0 2px;
	}

	.page-jump {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font: 600 12px/1 "Barlow", sans-serif;
		color: #3f5f84;
	}

	.page-jump input {
		width: 72px;
		border: 1px solid #bfd9f5;
		border-radius: 8px;
		padding: 6px 8px;
		font: 600 12px/1 "Barlow", sans-serif;
		color: #114b86;
		background: #fff;
	}

	.pdf-canvas-wrap {
		margin-top: 12px;
		background: #fff;
		border: 1px solid #d7e2ee;
		border-radius: 8px;
		overflow: auto;
		max-height: 76vh;
	}

	.pdf-canvas-wrap canvas,
	.answer-canvas-wrap canvas {
		display: block;
		margin: 0 auto;
		width: 100%;
		height: auto;
		max-width: 980px;
	}

	.pdf-note {
		margin: 10px 0 0;
		font-size: 13px;
		color: #466789;
	}

	.answer-modal[hidden] {
		display: none;
	}

	.answer-modal {
		position: fixed;
		inset: 0;
		z-index: 3000;
		background: rgba(7, 24, 44, 0.62);
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 20px;
	}

	.answer-modal-dialog {
		width: min(1020px, 100%);
		max-height: calc(100vh - 40px);
		display: flex;
		flex-direction: column;
		border-radius: 12px;
		border: 1px solid #b7d2ee;
		background: #f8fbff;
		overflow: hidden;
	}

	.answer-modal-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		padding: 10px 12px;
		border-bottom: 1px solid #d7e2ee;
	}

	.answer-modal-header strong {
		font: 700 14px/1.2 "Exo 2", sans-serif;
		color: #123b6c;
	}

	.answer-modal-header button {
		border: 1px solid #bfd9f5;
		background: #fff;
		color: #114b86;
		border-radius: 8px;
		padding: 7px 10px;
		font: 700 12px/1 "Exo 2", sans-serif;
		cursor: pointer;
	}

	.answer-canvas-wrap {
		background: #fff;
		overflow: auto;
		padding: 8px;
		max-height: calc(100vh - 150px);
	}

	.answer-status {
		margin: 0;
		padding: 8px 12px 10px;
		font: 600 12px/1.3 "Barlow", sans-serif;
		color: #3f5f84;
		border-top: 1px solid #d7e2ee;
	}

	body.answer-open {
		overflow: hidden;
	}

	@media (max-width: 700px) {
		.pdf-toolbar-actions {
			width: 100%;
			gap: 6px;
		}

		.pdf-toolbar-actions button,
		.page-jump {
			flex: 1 1 calc(50% - 6px);
		}

		.page-jump {
			justify-content: center;
		}

		.page-jump input {
			width: 64px;
		}

		.answer-modal {
			padding: 0;
		}

		.answer-modal-dialog {
			width: 100%;
			height: 100%;
			max-height: 100%;
			border-radius: 0;
		}

		.answer-canvas-wrap {
			max-height: none;
			flex: 1;
		}
	}
</style>

<script type="module">
	const workers = new Set();
	const viewers = Array.from(document.querySelectorAll("[data-pdf-viewer]"));

	if (viewers.length) {
		const pdfjsLib = await import("https://cdn.jsdelivr.net/npm/pdfjs-dist@4.4.168/build/pdf.min.mjs");
		const workerUrl = "https://cdn.jsdelivr.net/npm/pdfjs-dist@4.4.168/build/pdf.worker.min.mjs";
		if (!workers.has(workerUrl)) {
			pdfjsLib.GlobalWorkerOptions.workerSrc = workerUrl;
			workers.add(workerUrl);
		}

		for (const root of viewers) {
			const canvas = root.querySelector('[data-role="canvas"]');
			const status = root.querySelector('[data-role="status"]');
			const prevBtn = root.querySelector('[data-action="prev"]');
			const nextBtn = root.querySelector('[data-action="next"]');
			const firstBtn = root.querySelector('[data-action="first"]');
			const gotoBtn = root.querySelector('[data-action="goto"]');
			const answerBtn = root.querySelector('[data-action="answer"]');
			const pageInput = root.querySelector('[data-role="page-input"]');
			const answerModal = root.querySelector('[data-role="answer-modal"]');
			const answerCanvas = root.querySelector('[data-role="answer-canvas"]');
			const answerStatus = root.querySelector('[data-role="answer-status"]');
			const answerCloseBtn = root.querySelector('[data-action="answer-close"]');
			const pdfPath = root.getAttribute("data-pdf-path");

			if (!(canvas instanceof HTMLCanvasElement) || !(status instanceof HTMLElement) || !pdfPath) continue;
			if (!(prevBtn instanceof HTMLButtonElement) || !(nextBtn instanceof HTMLButtonElement)) continue;
			if (!(firstBtn instanceof HTMLButtonElement) || !(gotoBtn instanceof HTMLButtonElement)) continue;
			if (!(answerBtn instanceof HTMLButtonElement) || !(pageInput instanceof HTMLInputElement)) continue;
			if (!(answerModal instanceof HTMLElement) || !(answerCanvas instanceof HTMLCanvasElement)) continue;
			if (!(answerStatus instanceof HTMLElement) || !(answerCloseBtn instanceof HTMLButtonElement)) continue;

			const ctx = canvas.getContext("2d");
			const answerCtx = answerCanvas.getContext("2d");
			if (!ctx || !answerCtx) continue;

			let pdfDoc = null;
			let pageNum = 1;
			let pageCount = 1;
			let rendering = false;
			let pendingPage = null;
			let answerRendered = false;
			let answerRendering = false;

			const syncToolbar = () => {
				status.textContent = `Sayfa ${pageNum} / ${pageCount}`;
				pageInput.max = String(pageCount);
				pageInput.value = String(pageNum);
			};

			const updateButtons = () => {
				const isSinglePage = pageCount <= 1;
				prevBtn.disabled = isSinglePage || pageNum <= 1;
				nextBtn.disabled = isSinglePage || pageNum >= pageCount;
				firstBtn.disabled = isSinglePage || pageNum === 1;
				gotoBtn.disabled = isSinglePage;
				answerBtn.disabled = isSinglePage;
				pageInput.disabled = isSinglePage;
			};

			const renderPage = async (num) => {
				if (!pdfDoc) return;
				rendering = true;

				const page = await pdfDoc.getPage(num);
				const baseViewport = page.getViewport({ scale: 1 });
				const targetWidth = Math.min(980, root.clientWidth - 24);
				const scale = Math.max(1, targetWidth / baseViewport.width);
				const viewport = page.getViewport({ scale });

				canvas.width = viewport.width;
				canvas.height = viewport.height;
				await page.render({ canvasContext: ctx, viewport }).promise;

				rendering = false;
				syncToolbar();
				updateButtons();

				if (pendingPage !== null) {
					const queued = pendingPage;
					pendingPage = null;
					await queueRender(queued);
				}
			};

			const queueRender = async (num) => {
				pageNum = Math.min(Math.max(1, num), pageCount);
				if (rendering) {
					pendingPage = pageNum;
					return;
				}
				await renderPage(pageNum);
			};

			const goToPageFromInput = async () => {
				const raw = Number.parseInt(pageInput.value, 10);
				const targetPage = Number.isNaN(raw) ? pageNum : raw;
				await queueRender(targetPage);
			};

			const renderAnswerPage = async () => {
				if (!pdfDoc || answerRendering || answerRendered) return;
				answerRendering = true;
				answerStatus.textContent = "Cevap anahtari yukleniyor...";

				try {
					const page = await pdfDoc.getPage(pageCount);
					const baseViewport = page.getViewport({ scale: 1 });
					const dialog = answerModal.querySelector(".answer-modal-dialog");
					const dialogWidth = dialog instanceof HTMLElement ? dialog.clientWidth : root.clientWidth;
					const targetWidth = Math.min(980, dialogWidth - 32);
					const scale = Math.max(1, targetWidth / baseViewport.width);
					const viewport = page.getViewport({ scale });

					answerCanvas.width = viewport.width;
					answerCanvas.height = viewport.height;
					await page.render({ canvasContext: answerCtx, viewport }).promise;
					answerStatus.textContent = `Son sayfa hazir (${pageCount}. sayfa)`;
					answerRendered = true;
				} catch {
					answerStatus.textContent = "Cevap anahtari yuklenemedi";
				}

				answerRendering = false;
			};

			const openAnswerModal = async () => {
				answerModal.hidden = false;
				document.body.classList.add("answer-open");
				await renderAnswerPage();
			};

			const closeAnswerModal = () => {
				answerModal.hidden = true;
				document.body.classList.remove("answer-open");
			};

			try {
				const loadingTask = pdfjsLib.getDocument(pdfPath);
				pdfDoc = await loadingTask.promise;
				pageCount = pdfDoc.numPages;
				await queueRender(1);
			} catch {
				status.textContent = "PDF yuklenemedi";
				continue;
			}

			prevBtn.addEventListener("click", async () => {
				await queueRender(pageNum - 1);
			});

			nextBtn.addEventListener("click", async () => {
				await queueRender(pageNum + 1);
			});

			firstBtn.addEventListener("click", async () => {
				await queueRender(1);
			});

			gotoBtn.addEventListener("click", goToPageFromInput);
			pageInput.addEventListener("keydown", async (event) => {
				if (event.key === "Enter") {
					event.preventDefault();
					await goToPageFromInput();
				}
			});

			answerBtn.addEventListener("click", openAnswerModal);
			answerCloseBtn.addEventListener("click", closeAnswerModal);
			answerModal.addEventListener("click", (event) => {
				if (event.target === answerModal) closeAnswerModal();
			});

			document.addEventListener("keydown", (event) => {
				if (event.key === "Escape" && !answerModal.hidden) {
					closeAnswerModal();
				}
			});
		}
	}
</script>
