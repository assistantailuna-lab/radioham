---
interface Props {
	slotId?: string;
	minHeight?: string;
	label?: string;
}

const {
	slotId = import.meta.env.PUBLIC_ADSENSE_SLOT_DEFAULT ?? "",
	minHeight = "120px",
	label = "Advertisement",
} = Astro.props;
const client = import.meta.env.PUBLIC_ADSENSE_CLIENT ?? "";
---

<div class="ad-wrap" style={`min-height:${minHeight}`}>
	<p class="ad-label">{label}</p>
	{
		client && slotId ? (
			<ins
				class="adsbygoogle"
				style="display:block"
				data-ad-client={client}
				data-ad-slot={slotId}
				data-ad-format="auto"
				data-full-width-responsive="true"
			></ins>
		) : (
			<div class="ad-placeholder">
				AdSense placeholder
			</div>
		)
	}
</div>

{
	client && slotId && (
		<script is:inline>
			(adsbygoogle = window.adsbygoogle || []).push({});
		</script>
	)
}

<style>
	.ad-wrap {
		border: 1px dashed #c7d5e8;
		background: #f9fcff;
		border-radius: 8px;
		padding: 10px;
	}

	.ad-label {
		margin: 0 0 8px;
		font-size: 11px;
		letter-spacing: 0.8px;
		text-transform: uppercase;
		color: #7890b0;
	}

	.ad-placeholder {
		display: grid;
		place-items: center;
		min-height: 80px;
		color: #5f7391;
		font-size: 13px;
		background: #eef4fb;
		border-radius: 5px;
	}
</style>
