---
import Layout from "../layouts/Layout.astro";
import SiteNav from "../components/SiteNav.astro";
import SiteFooter from "../components/SiteFooter.astro";
import "../styles/site.css";
---

<Layout
	lang="tr"
	title="APRS Thursday | RadioHam"
	description="Türkiye APRS noktalarını görüntüleyin ve APRS.to canlı haritasına ulaşın."
>
	<SiteNav lang="tr" current="aprs" />

	<section class="page-hero">
		<div class="container">
			<h1>APRS Thursday</h1>
			<p>APRS görünümü ve APRS canlı harita bağlantıları.</p>
		</div>
	</section>

	<section class="section">
		<div class="container">
			<div class="outline-section">
				<div class="aprs-map-shell">
					<div class="aprs-map-head">
						<p class="aprs-link-row">
							<a
								class="aprs-external-link"
								href="https://aprs.to/"
								target="_blank"
								rel="noopener noreferrer"
							>
								APRS.to Canlı Haritayı Aç
							</a>
							<a
								class="aprs-external-link"
								href="https://aprs.fi/"
								target="_blank"
								rel="noopener noreferrer"
							>
								APRS.fi Canlı Haritayı Aç
							</a>
						</p>
						<h2>APRS Thursday</h2>
						<p>Canlı APRS izleme için APRS.to veya APRS.fi haritasını açabilirsiniz.</p>
					</div>
					<div class="aprs-map-frame-wrap">
						<iframe
							class="aprs-map-frame"
							title="Türkiye APRS ve Röle Haritası"
							src="https://www.google.com/maps/d/embed?mid=1PZI2odXrv3I_d_w8aUnYLy_21DFFvZc"
							loading="lazy"
							referrerpolicy="no-referrer-when-downgrade"
						></iframe>
					</div>
					<p class="aprs-small-link">
						<a href="https://aprsph.net/" target="_blank" rel="noopener noreferrer">aprsph.net</a>
					</p>
				</div>
			</div>
		</div>
	</section>

	<SiteFooter lang="tr" />
</Layout>

<style>
	.aprs-map-shell {
		border: 1px solid #d7e2ee;
		border-radius: 12px;
		padding: 12px;
		background: #fff;
	}

	.aprs-map-head h2 {
		margin: 0;
		font: 700 22px/1.2 "Exo 2", sans-serif;
		color: #123b6c;
	}

	.aprs-map-head p {
		margin: 6px 0 10px;
		color: #355b82;
		font-size: 14px;
	}

	.aprs-link-row {
		margin: 10px 0 12px;
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.aprs-external-link {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 11px 16px;
		border: 1px solid #0c4c90;
		border-radius: 999px;
		background:
			radial-gradient(120% 140% at 15% 10%, rgba(255, 255, 255, 0.3), rgba(255, 255, 255, 0) 40%),
			linear-gradient(135deg, #0a4d94 0%, #0f67bf 55%, #3ea2ff 100%);
		color: #ffffff;
		font: 800 13px/1 "Exo 2", sans-serif;
		letter-spacing: 0.2px;
		text-decoration: none;
		box-shadow:
			0 8px 20px rgba(12, 76, 144, 0.28),
			inset 0 1px 0 rgba(255, 255, 255, 0.22);
		transition: transform 0.18s ease, box-shadow 0.18s ease, filter 0.18s ease;
	}

	.aprs-external-link:hover {
		transform: translateY(-1px);
		filter: saturate(1.05);
		box-shadow:
			0 12px 26px rgba(12, 76, 144, 0.34),
			inset 0 1px 0 rgba(255, 255, 255, 0.3);
	}

	.aprs-external-link::after {
		content: "↗";
		font-size: 13px;
		line-height: 1;
		opacity: 0.95;
	}

	.aprs-external-link:focus-visible {
		outline: 2px solid #7dc3ff;
		outline-offset: 2px;
	}

	.aprs-map-frame-wrap {
		border: 1px solid #d7e2ee;
		border-radius: 10px;
		overflow: hidden;
		background: #eef4fb;
	}

	.aprs-map-frame {
		display: block;
		width: 100%;
		height: min(72vh, 760px);
		border: 0;
	}

	.aprs-small-link {
		margin: 8px 2px 0;
		font: 500 12px/1.2 "Barlow", sans-serif;
	}

	.aprs-small-link a {
		color: #5a7796;
		text-decoration: none;
	}

	.aprs-small-link a:hover {
		text-decoration: underline;
	}

	@media (max-width: 820px) {
		.aprs-map-frame {
			height: min(58vh, 460px);
		}
	}
</style>


