---
import Layout from "../../layouts/Layout.astro";
import SiteNav from "../../components/SiteNav.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { buildSubtopicArticle } from "../../data/subtopic-content";
import { listSubtopics } from "../../data/guide";
import "../../styles/site.css";

export async function getStaticPaths() {
	const topics = listSubtopics("tr");
	const canonicalPaths = topics.map((subtopic) => ({
		params: { slug: subtopic.slug },
		props: { subtopic },
	}));

	const redirectPaths = topics.flatMap((subtopic) =>
		subtopic.legacySlugs.map((legacySlug) => ({
			params: { slug: legacySlug },
			props: { redirectTo: `/konu/${subtopic.slug}` },
		}))
	);

	return [...canonicalPaths, ...redirectPaths];
}

const { subtopic, redirectTo } = Astro.props;
if (redirectTo) {
	return Astro.redirect(redirectTo, 301);
}

const article = buildSubtopicArticle("tr", subtopic);
const answerHeading = subtopic.code === "1.1" ? "Amatör Telsizcilik" : "Açıklama";
const siteUrl = (import.meta.env.SITE_URL || "https://radioham.site").replace(/\/$/, "");
const topicPath = `/konu/${subtopic.slug}`;
const topicUrl = `${siteUrl}${topicPath}`;
const jsonLd = [
	{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		itemListElement: [
			{
				"@type": "ListItem",
				position: 1,
				name: "Ana Sayfa",
				item: siteUrl,
			},
			{
				"@type": "ListItem",
				position: 2,
				name: "Rehber",
				item: `${siteUrl}/rehber`,
			},
			{
				"@type": "ListItem",
				position: 3,
				name: article.title,
				item: topicUrl,
			},
		],
	},
	{
		"@context": "https://schema.org",
		"@type": "Article",
		headline: article.title,
		description: article.plainExplanation,
		inLanguage: "tr-TR",
		mainEntityOfPage: topicUrl,
		author: {
			"@type": "Organization",
			name: "RadioHam",
		},
		publisher: {
			"@type": "Organization",
			name: "RadioHam",
			logo: {
				"@type": "ImageObject",
				url: `${siteUrl}/logo2.png`,
			},
		},
	},
];
---

<Layout
	lang="tr"
	title={`${article.title} | RadioHam`}
	description={article.plainExplanation}
	canonical={topicPath}
	jsonLd={jsonLd}
>
	<SiteNav lang="tr" current="guide" />

	<section class="page-hero">
		<div class="container">
			<h1>{article.title}</h1>
			<p>Kısa ve net cevap aşağıdadır.</p>
		</div>
	</section>

	<section class="section">
		<div class="container">
			<div class="outline">
				<article class="outline-section">
					<h3>{answerHeading}</h3>
					<p>{article.plainExplanation}</p>
				</article>
				<article class="outline-section">
					<h3>Detaylı Açıklama</h3>
					{article.deepDive.map((paragraph) => <p>{paragraph}</p>)}
				</article>
				<article class="outline-section">
					<h3>Neden Önemli?</h3>
					<ul>
						{article.whyItMatters.map((item) => <li>{item}</li>)}
					</ul>
				</article>
				<article class="outline-section">
					<h3>Adım Adım Uygulama</h3>
					<ol>
						{article.stepByStep.map((item) => <li>{item}</li>)}
					</ol>
				</article>
				<article class="outline-section">
					<h3>Sahadan Kısa Örnek</h3>
					<p>{article.realLifeExample}</p>
				</article>
				<article class="outline-section">
					<h3>Sık Yapılan Hatalar</h3>
					<ul>
						{article.commonMistakes.map((item) => <li>{item}</li>)}
					</ul>
				</article>
				<article class="outline-section">
					<h3>Hızlı Kontrol Listesi</h3>
					<ul>
						{article.quickCheck.map((item) => <li>{item}</li>)}
					</ul>
				</article>
				<article class="outline-section">
					<h3>Kaynaklar</h3>
					<ul>
						{
							article.sources.map((source) => (
								<li>
									<a href={source.url} target="_blank" rel="noopener noreferrer">
										{source.label}
									</a>
								</li>
							))
						}
					</ul>
				</article>
			</div>
		</div>
	</section>

	<SiteFooter lang="tr" />
</Layout>

