		font: 600 14px/1.2 "Barlow", sans-serif;
	}

	.actions {
		display: flex;
		gap: 10px;
		align-items: center;
		flex-wrap: wrap;
	}

	.calc-btn {
		border: 1px solid #2c6caf;
		background: #2c6caf;
