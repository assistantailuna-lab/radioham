	}

	.calc-box {
		border: 1px solid #d7e2ee;
		border-radius: 12px;
		padding: 14px;
		background: #fff;
		display: grid;
		gap: 12px;
	}

	.fields {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 10px;
	}

	.fields label {
		display: grid;
		gap: 5px;
		font: 600 13px/1.2 "Barlow", sans-serif;
