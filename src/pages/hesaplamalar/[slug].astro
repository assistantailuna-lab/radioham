						const los = 3.57 * (Math.sqrt(h1) + Math.sqrt(h2));
						const txDbm = wToDbm(txW);
						const rxSens = -118;
						const budgetLoss = 25;
						const maxFspl = txDbm - rxSens - budgetLoss;
						const powerLimited = Math.pow(10, (maxFspl - 32.44 - 20 * Math.log10(145)) / 20);
						const estimate = Math.min(los * env, powerLimited);
						return setResult(`LOS siniri ${fmt(los * env, 2)} km | Guc siniri ${fmt(powerLimited, 2)} km | Tahmini pratik menzil ${fmt(estimate, 2)} km`);
					}
					case "repeater-access": {
						const f = n("freqMHz");
						const txW = n("txW");
						const txGain = n("txGain");
						const rxGain = n("rxGain");
						const loss = n("loss");
						const rxSens = n("rxSens");
						const margin = n("margin");
						if (!(f > 0) || !(txW > 0)) return setResult("Frekans ve TX gucu pozitif olmali.");
						const txDbm = wToDbm(txW);
						const allowedFspl = txDbm + txGain + rxGain - loss - rxSens - margin;
						const km = Math.pow(10, (allowedFspl - 32.44 - 20 * Math.log10(f)) / 20);
						return setResult(`Izin verilen FSPL ${fmt(allowedFspl, 2)} dB | Tahmini erisim mesafesi ${fmt(km, 2)} km`);
					}
					case "height-coverage": {
						const oldH = n("oldH");
						const newH = n("newH");
						const otherH = n("otherH");
						if (!(oldH > 0) || !(newH > 0) || !(otherH > 0)) return setResult("Yukseklikler pozitif olmali.");
						const oldRange = 3.57 * (Math.sqrt(oldH) + Math.sqrt(otherH));
						const newRange = 3.57 * (Math.sqrt(newH) + Math.sqrt(otherH));
						const delta = newRange - oldRange;
						const pct = (delta / oldRange) * 100;
						return setResult(`Eski ${fmt(oldRange, 2)} km | Yeni ${fmt(newRange, 2)} km | Artis ${fmt(delta, 2)} km (%${fmt(pct, 1)})`);
					}
					case "qrp-vs-high": {
						const lowW = n("lowW");
						const highW = n("highW");
						if (!(lowW > 0) || !(highW > 0)) return setResult("Guc degerleri pozitif olmali.");
						const db = 10 * Math.log10(highW / lowW);
						const sDiff = db / 6;
						const fieldRatio = Math.pow(10, db / 20);
						return setResult(`dB farki ${fmt(db, 2)} dB | Yaklasik S-unit farki ${fmt(sDiff, 2)} S | Alan siddeti katsayisi x${fmt(fieldRatio, 2)}`);
					}
					case "s-unit": {
						const dbDiff = n("dbDiff");
						if (!Number.isFinite(dbDiff)) return setResult("dB farki girin.");
						const s = dbDiff / 6;
						return setResult(`${fmt(dbDiff, 2)} dB ~= ${fmt(s, 2)} S-unit`);
					}
					case "db-effect": {
						const db = n("db");
						if (!Number.isFinite(db)) return setResult("dB degeri girin.");
						const power = Math.pow(10, db / 10);
						const voltage = Math.pow(10, db / 20);
						const rangeFactor = voltage;
						return setResult(`Guc katsayisi x${fmt(power, 3)} | Gerilim/alan katsayisi x${fmt(voltage, 3)} | Serbest uzayda menzil katsayisi yaklasik x${fmt(rangeFactor, 3)}`);
					}
					case "channel-spacing": {
						const start = n("startMHz");
						const end = n("endMHz");
						const channels = n("channels");
						if (!(end > start) || !(channels >= 2)) return setResult("Bitis frekansi baslangictan buyuk ve kanal sayisi en az 2 olmali.");
						const spacingMHz = (end - start) / (channels - 1);
						return setResult(`Kanal araligi: ${fmt(spacingMHz * 1000, 3)} kHz (${fmt(spacingMHz, 6)} MHz)`);
					}
					case "offset": {
						const rx = n("rxMHz");
						const preset = t("preset");
						const customKHz = n("customKHz");
						let dir = t("direction");
						let offsetMHz = 0;
						if (!(rx > 0)) return setResult("Role RX frekansi pozitif olmali.");
						if (preset === "vhf-tr") {
							offsetMHz = 0.6;
							dir = "minus";
						} else if (preset === "uhf-tr") {
							offsetMHz = 7.6;
							dir = "minus";
						} else {
							if (!(customKHz >= 0)) return setResult("Ozel offset (kHz) 0 veya daha buyuk olmali.");
							offsetMHz = customKHz / 1000;
						}
						const tx = dir === "plus" ? rx + offsetMHz : rx - offsetMHz;
						const sign = dir === "plus" ? "+" : "-";
						return setResult(
							`Role RX: ${fmt(rx, 3)} MHz | TX: ${fmt(tx, 3)} MHz | Offset: ${sign}${fmt(offsetMHz, 3)} MHz (${fmt(offsetMHz * 1000, 0)} kHz)
TR pratik notu: Genelde role cikis frekansi RX olarak yazilir; sizin telsizinizin gonderecegi frekans TX'tir. VHF'de cogunlukla TX = RX - 0.600 MHz, UHF'de TX = RX - 7.600 MHz.`
						);
					}
					case "duplex-split": {
						const rx = n("rxMHz");
						const splitKHz = n("splitKHz");
						const direction = t("direction");
						if (!(rx > 0) || !(splitKHz >= 0)) return setResult("RX ve split degerleri gecerli olmali.");
						const delta = splitKHz / 1000;
						const tx = direction === "plus" ? rx + delta : rx - delta;
						return setResult(`RX: ${fmt(rx, 3)} MHz | TX: ${fmt(tx, 3)} MHz | Split: ${direction === "plus" ? "+" : "-"}${fmt(delta, 3)} MHz`);
					}
					case "ctcss-dcs": {
						const mode = t("mode").toUpperCase();
						const code = t("code");
						const dir = t("direction");
						if (!code) return setResult("Ton/kod degeri girin.");
						const tx = `${mode} TX: ${code}`;
						const rx = dir === "tx-rx" ? `${mode} RX: ${code}` : `${mode} RX: OFF`;
						return setResult(`${tx} | ${rx} | SQL modu: ${dir === "tx-rx" ? "Tone Squelch" : "Carrier Squelch"}`);
					}
					case "aprs-interval": {
						const speed = n("speed");
						const profile = t("profile");
						const mode = t("powerMode");
						if (!(speed >= 0)) return setResult("Hiz 0 veya daha buyuk olmali.");
						let base = 180;
						if (profile === "static") base = 900;
						if (profile === "portable") base = 300;
						if (profile === "mobile") base = 120;
						const speedFactor = speed > 0 ? clamp(60 / speed, 0.35, 2.5) : 3;
						const modeFactor = mode === "max-saving" ? 1.7 : mode === "tracking" ? 0.65 : 1;
						const sec = Math.round(clamp(base * speedFactor * modeFactor, 20, 1800));
						return setResult(`Onerilen beacon araligi: ${sec} sn (${fmt(sec / 60, 1)} dk)`);
					}
					case "doppler": {
						const f = n("freqMHz");
						const v = n("speedKms") * 1000;
						if (!(f > 0) || !(v > 0)) return setResult("Frekans ve bagil hiz pozitif olmali.");
						const c = 299792458;
						const shift = (f * 1e6) * (v / c);
						return setResult(`Yaklasma/uzaklasmada tepe Doppler: +/-${fmt(shift, 0)} Hz (yaklasik +/-${fmt(shift / 1000, 2)} kHz)`);
					}
					case "grid-converter": {
						const mode = t("mode");
						const lat = n("lat");
						const lon = n("lon");
						const grid = t("grid");
						if (mode === "latlon-to-grid") {
							if (!Number.isFinite(lat) || !Number.isFinite(lon)) return setResult("Lat ve lon girin.");
							const out = latLonToGrid(lat, lon);
							if (!out) return setResult("Lat/Lon gecerli aralikta olmali.");
							setField("grid", out);
							return setResult(`Grid locator: ${out}`);
						}
						if (mode === "grid-to-latlon") {
							if (!grid) return setResult("Grid degeri girin.");
							const out = gridToLatLon(grid);
							if (!out) return setResult("Grid formati gecersiz. Ornek: KN40 veya KN40aa");
							setField("lat", fmt(out.lat, 5));
							setField("lon", fmt(out.lon, 5));
							return setResult(`Merkez koordinat: ${fmt(out.lat, 5)}, ${fmt(out.lon, 5)}`);
						}
						return setResult("Donusum modunu secin.");
					}
					case "bearing-distance": {
						const lat1 = n("lat1");
						const lon1 = n("lon1");
						const lat2 = n("lat2");
						const lon2 = n("lon2");
						if (![lat1, lon1, lat2, lon2].every(Number.isFinite)) return setResult("Tum koordinat alanlari gecerli olmali.");
						const R = 6371;
						const phi1 = deg2rad(lat1);
						const phi2 = deg2rad(lat2);
						const dPhi = deg2rad(lat2 - lat1);
						const dLambda = deg2rad(lon2 - lon1);
						const a = Math.sin(dPhi / 2) ** 2 + Math.cos(phi1) * Math.cos(phi2) * Math.sin(dLambda / 2) ** 2;
						const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
						const dist = R * c;
						const y = Math.sin(dLambda) * Math.cos(phi2);
						const x = Math.cos(phi1) * Math.sin(phi2) - Math.sin(phi1) * Math.cos(phi2) * Math.cos(dLambda);
						const bearing = norm360(rad2deg(Math.atan2(y, x)));
						return setResult(`Mesafe: ${fmt(dist, 2)} km | Ilk bearing: ${fmt(bearing, 1)} deg`);
					}
					case "sat-visibility": {
						const maxEl = n("maxEl");
						const period = n("period");
						if (!(maxEl > 0 && maxEl <= 90) || !(period > 0)) return setResult("Maks elevasyon 0-90, periyot pozitif olmali.");
						const duration = estimatePassDuration(maxEl, period);
						return setResult(`Tahmini gorunurluk suresi: ${fmt(duration, 1)} dakika (basit geometri modeli)`);
					}
					case "hf-solar-guide": {
						const sfi = n("sfi");
						const kp = n("kp");
						const period = t("period");
						if (!(sfi > 0) || !(kp >= 0)) return setResult("SFI ve Kp degerlerini kontrol edin.");
						const bands = [
							{ name: "80m", f: 3.6 },
							{ name: "40m", f: 7.1 },
							{ name: "30m", f: 10.1 },
							{ name: "20m", f: 14.2 },
							{ name: "17m", f: 18.1 },
							{ name: "15m", f: 21.2 },
							{ name: "12m", f: 24.9 },
							{ name: "10m", f: 28.5 },
						];
						const baseMuf = period === "day" ? 10 + 0.12 * (sfi - 70) : 6 + 0.07 * (sfi - 70);
						const kpPenalty = clamp(1 - 0.08 * kp, 0.55, 1);
						const effectiveMuf = Math.max(4, baseMuf * kpPenalty);
						const open = bands.filter((b) => b.f <= effectiveMuf * (period === "day" ? 0.95 : 0.85)).map((b) => b.name);
						if (period === "night" && !open.includes("40m")) open.unshift("40m");
						if (period === "night" && !open.includes("80m")) open.unshift("80m");
						const note = kp >= 4 ? "Geomanyetik aktivite yuksek, uzun kutup rotalarinda zayiflama olabilir." : "Kp sakin, band davranisi daha stabil olabilir.";
						return setResult(`Tahmini etkili MUF: ${fmt(effectiveMuf, 1)} MHz | Onerilen bantlar: ${open.join(", ") || "80m, 40m"} | ${note}`);
					}
					case "muf-luf": {
						const fof2 = n("fof2");
						const noise = n("noise");
						const pathFactor = n("pathFactor");
						if (!(fof2 > 0) || !(noise > 0) || !(pathFactor > 0)) return setResult("Tum alanlar pozitif olmali.");
						const muf = fof2 * pathFactor;
						const noiseNorm = clamp((noise - 1) / 4, 0, 1);
						const luf = clamp(Math.max(1.8, muf * (0.15 + 0.30 * noiseNorm)), 1.8, muf * 0.9);
						const ouf = muf * 0.85;
						return setResult(`MUF: ${fmt(muf, 2)} MHz | OUF (onerilen ust sinir): ${fmt(ouf, 2)} MHz | LUF: ${fmt(luf, 2)} MHz | Tahmini pencere: ${fmt(luf, 2)} - ${fmt(ouf, 2)} MHz`);
					}
					case "greyline": {
						const lat = n("lat");
						const lon = n("lon");
						const raw = t("datetime");
						if (!Number.isFinite(lat) || !Number.isFinite(lon) || !raw) return setResult("Lat, lon ve tarih gerekli.");
						const date = new Date(raw.endsWith("Z") ? raw : `${raw}Z`);
						const elev = solarElevation(lat, lon, date);
						const isGreyline = elev <= 0 && elev >= -6;
						return setResult(`Gunes elevasyonu: ${fmt(elev, 2)} deg | Durum: ${isGreyline ? "Greyline penceresinde" : "Greyline disinda"}`);
					}
					case "sun-band": {
						const lat = n("lat");
						const lon = n("lon");
						const raw = t("date");
						if (!Number.isFinite(lat) || !Number.isFinite(lon) || !raw) return setResult("Lat, lon ve tarih gerekli.");
						const date = new Date(`${raw}T12:00:00Z`);
						const times = sunriseSunsetUTC(lat, lon, date);
						if (!times) return setResult("Bu enlemde secili tarihte gunes dogumu/batimi yok (kutup kosullari).");
						return setResult(`Gun dogumu ${times.sunrise} UTC | Gun batimi ${times.sunset} UTC | Oneri: Dogum/batim penceresi 20m-30m-40m, gun ortasi 15m-17m-20m, gece 40m-60m-80m`);
					}
					default:
						return setResult("Bu hesaplama icin isleyici bulunamadi.");
				}
			} catch (err) {
				setResult("Hesaplama sirasinda bir hata olustu. Degerleri kontrol edin.");
				console.error(err);
			}
		};

		document.getElementById("runCalc")?.addEventListener("click", compute);
		document.querySelectorAll("[data-field]").forEach((el) => {
			el.addEventListener("change", compute);
		});
		compute();
	});
</script>

