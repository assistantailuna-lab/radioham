---
import Layout from "../../layouts/Layout.astro";
import SiteNav from "../../components/SiteNav.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import "../../styles/site.css";
import { calculatorBySlug, calculatorCategories, calculators } from "../../data/calculators";
import { trDisplay } from "../../utils/trDisplay";

export function getStaticPaths() {
	return calculators.map((item) => ({ params: { slug: item.slug } }));
}

const slug = Astro.params.slug ?? "";
const calc = calculatorBySlug.get(slug);

if (!calc) {
	throw new Error(`Hesaplama bulunamadı: ${slug}`);
}

const category = calculatorCategories.find((item) => item.key === calc.category);
---

<Layout lang="tr" title={`${trDisplay(calc.title)} | RadioHam`} description={trDisplay(calc.description)}>
	<SiteNav lang="tr" current="calculators" />

	<section class="page-hero">
		<div class="container">
			<nav class="crumb"><a href="/hesaplamalar">Hesaplamalar</a> / <span>{trDisplay(calc.title)}</span></nav>
			<h1>{trDisplay(calc.title)}</h1>
			<p>{trDisplay(calc.description)}</p>
			{category && <p class="cat">Kategori: {trDisplay(category.title)}</p>}
		</div>
	</section>

	<section class="section">
		<div class="container">
			<article class="calc-box" data-formula={calc.formula}>
				<div class="fields">
					{calc.fields.map((field) => (
						<label>
							<span>{trDisplay(field.label)}{field.unit ? ` (${field.unit})` : ""}</span>
							{field.type === "select" ? (
								<select id={field.id} data-field={field.id} data-default={field.value}>
									{field.options?.map((opt) => (
										<option value={opt.value} selected={String(field.value ?? "") === opt.value}>{trDisplay(opt.label)}</option>
									))}
								</select>
							) : (
								<input
									id={field.id}
									data-field={field.id}
									data-default={field.value}
									type={field.type === "date" ? "date" : field.type === "datetime-local" ? "datetime-local" : field.type === "text" ? "text" : "number"}
									step={field.type === "number" ? field.step ?? "any" : undefined}
									min={field.type === "number" ? field.min : undefined}
									value={field.value}
									placeholder={field.placeholder}
								/>
							)}
						</label>
					))}
				</div>
				<div class="actions">
					<button type="button" id="runCalc" class="calc-btn">Hesapla</button>
					<a href="/hesaplamalar" class="back-link">Tüm hesaplamalar</a>
				</div>
				<p class="result" id="calcResult">-</p>
				{calc.note && <p class="note">Not: {trDisplay(calc.note)}</p>}
			</article>
		</div>
	</section>

	<SiteFooter lang="tr" />
</Layout>

<script>
	document.addEventListener("DOMContentLoaded", () => {
		const box = document.querySelector(".calc-box");
		if (!(box instanceof HTMLElement)) return;
		const formula = box.dataset.formula || "";

		const resultEl = document.getElementById("calcResult");
		const trText = (value) => {
			const map = [
				["Akim", "Ak\u0131m"],
				["akim", "ak\u0131m"],
				["Aku", "Ak\u00fc"],
				["aku", "ak\u00fc"],
				["Alici", "Al\u0131c\u0131"],
				["Ayni", "Ayn\u0131"],
				["ayni", "ayn\u0131"],
				["Arasi", "Aras\u0131"],
				["Baslangic", "Ba\u015flang\u0131\u00e7"],
				["Cekisi", "\u00c7eki\u015fi"],
				["Calisma", "\u00c7al\u0131\u015fma"],
				["calisma", "\u00e7al\u0131\u015fma"],
				["Cevre", "\u00c7evre"],
				["cevre", "\u00e7evre"],
				["ceyrek", "\u00e7eyrek"],
				["Cikis", "\u00c7\u0131k\u0131\u015f"],
				["Donusum", "D\u00f6n\u00fc\u015f\u00fcm"],
				["Dusumu", "D\u00fc\u015f\u00fcm\u00fc"],
				["Duzeltme", "D\u00fczeltme"],
				["Gore", "G\u00f6re"],
				["gore", "g\u00f6re"],
				["Gorus", "G\u00f6r\u00fc\u015f"],
				["Guc", "G\u00fc\u00e7"],
				["guc", "g\u00fc\u00e7"],
				["Gunes", "G\u00fcne\u015f"],
				["gunes", "g\u00fcne\u015f"],
				["Gunluk", "G\u00fcnl\u00fck"],
				["gunluk", "g\u00fcnl\u00fck"],
				["Hesabi", "Hesab\u0131"],
				["Ikinci", "\u0130kinci"],
				["Ileri", "\u0130leri"],
				["Isletme", "\u0130\u015fletme"],
				["Istasyon", "\u0130stasyon"],
				["Karsilastirma", "Kar\u015f\u0131la\u015ft\u0131rma"],
				["karsilastirir", "kar\u015f\u0131la\u015ft\u0131r\u0131r"],
				["Kazanci", "Kazanc\u0131"],
				["Kullanim", "Kullan\u0131m"],
				["kullanim", "kullan\u0131m"],
				["Konusma", "Konu\u015fma"],
				["konusma", "konu\u015fma"],
				["Oranina", "Oran\u0131na"],
				["oranina", "oran\u0131na"],
				["Oneri", "\u00d6neri"],
				["Ozel", "\u00d6zel"],
				["Role", "R\u00f6le"],
				["Sarj", "\u015earj"],
				["sarj", "\u015farj"],
				["Secili", "Se\u00e7ili"],
				["Surekli", "S\u00fcrekli"],
				["surekli", "s\u00fcrekli"],
				["Sure", "S\u00fcre"],
				["Suresi", "S\u00fcresi"],
				["sure", "s\u00fcre"],
				["suresi", "s\u00fcresi"],
				["Tuketim", "T\u00fcketim"],
				["Uretim", "\u00dcretim"],
				["Yansiyan", "Yans\u0131yan"],
				["Yaklasik", "Yakla\u015f\u0131k"],
				["Yonu", "Y\u00f6n\u00fc"],
				["Yon", "Y\u00f6n"],
				["Yuksek", "Y\u00fcksek"],
				["Yukseklik", "Y\u00fckseklik"],
				["yuksek", "y\u00fcksek"],
				["yukseklik", "y\u00fckseklik"],
				["cikisi", "\u00e7\u0131k\u0131\u015f\u0131"],
				["degerlerinden", "de\u011ferlerinden"],
				["degerleri", "de\u011ferleri"],
				["degerler", "de\u011ferler"],
				["degeri", "de\u011feri"],
				["gecersiz", "ge\u00e7ersiz"],
				["girisi", "giri\u015fi"],
				["kisa", "k\u0131sa"],
				["olamadi", "olamad\u0131"],
				["olmali", "olmal\u0131"],
				["olustu", "olu\u015ftu"],
				["olc", "\u00f6l\u00e7"],
				["bakir", "bak\u0131r"],
				["kaybi", "kayb\u0131"],
				["hatti", "hatt\u0131"],
				["acik", "a\u00e7\u0131k"],
				["gecis", "ge\u00e7i\u015f"],
				["gorunurluk", "g\u00f6r\u00fcn\u00fcrl\u00fck"],
				["Turkiye", "T\u00fcrkiye"],
				["yon", "y\u00f6n"],
				["ucuncu", "\u00fc\u00e7\u00fcnc\u00fc"],
				["sagda", "sa\u011fda"],
				["siddeti", "\u015fiddeti"],
				["ust", "\u00fcst"],
				["yukari", "yukar\u0131"],
				["Tum", "T\u00fcm"],
				["tum", "t\u00fcm"],
				["Yuzde", "Y\u00fczde"],
				["yuzde", "y\u00fczde"],
				["Hiz", "H\u0131z"],
				["yarim", "yar\u0131m"],
				["Yarim", "Yar\u0131m"],
				["bes", "be\u015f"],
				["Bes", "Be\u015f"],
			];
			let text = String(value ?? "");
			for (const [from, to] of map) text = text.replaceAll(from, to);
			text = text
				.replaceAll("\u00c3\u00bc", "\u00fc")
				.replaceAll("\u00c3\u009c", "\u00dc")
				.replaceAll("\u00c3\u00b6", "\u00f6")
				.replaceAll("\u00c3\u0096", "\u00d6")
				.replaceAll("\u00c3\u00a7", "\u00e7")
				.replaceAll("\u00c3\u0087", "\u00c7")
				.replaceAll("\u00c4\u00b1", "\u0131")
				.replaceAll("\u00c4\u00b0", "\u0130")
				.replaceAll("\u00c5\u009f", "\u015f")
				.replaceAll("\u00c5\u009e", "\u015e")
				.replaceAll("\u00c4\u009f", "\u011f")
				.replaceAll("\u00c4\u009e", "\u011e");
			return text;
		};
		const setResult = (text) => {
			if (resultEl) resultEl.textContent = trText(text);
		};
		const getEl = (id) => document.getElementById(id);
		const n = (id) => {
			const el = getEl(id);
			if (!(el instanceof HTMLInputElement || el instanceof HTMLSelectElement)) return NaN;
			if (el instanceof HTMLInputElement && el.type === "number") {
				if (el.value.trim() === "") {
					const d = Number(el.dataset.default ?? "");
					return Number.isFinite(d) ? d : NaN;
				}
				return el.valueAsNumber;
			}
			if (String(el.value).trim() === "") {
				const d = Number(el.dataset.default ?? "");
				return Number.isFinite(d) ? d : NaN;
			}
			const parsed = Number(el.value);
			return Number.isFinite(parsed) ? parsed : NaN;
		};
		const t = (id) => {
			const el = getEl(id);
			if (!(el instanceof HTMLInputElement || el instanceof HTMLSelectElement)) return "";
			const raw = String(el.value || "").trim();
			if (raw !== "") return raw;
			return String(el.dataset.default || "").trim();
		};
		const setField = (id, value) => {
			const el = getEl(id);
			if (el instanceof HTMLInputElement || el instanceof HTMLSelectElement) el.value = String(value);
		};
		const fmt = (value, digits = 3) => (Number.isFinite(value) ? value.toFixed(digits) : "-");
		const clamp = (v, min, max) => Math.min(Math.max(v, min), max);
		const dbmToW = (dbm) => Math.pow(10, (dbm - 30) / 10);
		const wToDbm = (w) => 10 * Math.log10(w * 1000);
		const fsplDb = (freqMHz, distKm) => 32.44 + 20 * Math.log10(freqMHz) + 20 * Math.log10(distKm);
		const copperR = 0.0175;
		const earthR = 6371;
		const standards = [0.5, 1, 1.5, 2, 3, 4, 5, 6, 7.5, 10, 12.5, 15, 20, 25, 30, 40, 50, 63, 80, 100, 125, 160, 200];
		const cableStandards = [0.75, 1, 1.5, 2.5, 4, 6, 10, 16, 25, 35, 50, 70];
		const coaxCatalog = {
			RG58: { label: "RG-58", loss100At100: 10.5, diamMm: 4.95 },
			H155: { label: "H155", loss100At100: 9.0, diamMm: 5.4 },
			LMR240: { label: "LMR-240", loss100At100: 8.6, diamMm: 6.1 },
			RG213: { label: "RG-213", loss100At100: 6.7, diamMm: 10.3 },
			LMR400: { label: "LMR-400", loss100At100: 3.9, diamMm: 10.3 },
			HELIA12: { label: "1/2 in Heliax", loss100At100: 1.8, diamMm: 13.9 },
		};

		const deg2rad = (d) => (d * Math.PI) / 180;
		const rad2deg = (r) => (r * 180) / Math.PI;
		const norm360 = (d) => ((d % 360) + 360) % 360;
		const dayOfYear = (date) => {
			const start = Date.UTC(date.getUTCFullYear(), 0, 0);
			const now = Date.UTC(date.getUTCFullYear(), date.getUTCMonth(), date.getUTCDate());
			return Math.floor((now - start) / 86400000);
		};
		const solarDeclEqTime = (date) => {
			const doy = dayOfYear(date);
			const gamma = (2 * Math.PI / 365) * (doy - 1 + (date.getUTCHours() - 12) / 24);
			const eqTime = 229.18 * (0.000075 + 0.001868 * Math.cos(gamma) - 0.032077 * Math.sin(gamma) - 0.014615 * Math.cos(2 * gamma) - 0.040849 * Math.sin(2 * gamma));
			const decl = 0.006918 - 0.399912 * Math.cos(gamma) + 0.070257 * Math.sin(gamma) - 0.006758 * Math.cos(2 * gamma) + 0.000907 * Math.sin(2 * gamma) - 0.002697 * Math.cos(3 * gamma) + 0.00148 * Math.sin(3 * gamma);
			return { eqTime, decl };
		};
		const solarElevation = (lat, lon, date) => {
			const { eqTime, decl } = solarDeclEqTime(date);
			const minutes = date.getUTCHours() * 60 + date.getUTCMinutes() + date.getUTCSeconds() / 60;
			const trueSolar = norm360((minutes + eqTime + 4 * lon) * 0.25);
			const hourAngle = deg2rad(trueSolar < 180 ? trueSolar - 180 : trueSolar - 540);
			const latR = deg2rad(lat);
			const cosZenith = Math.sin(latR) * Math.sin(decl) + Math.cos(latR) * Math.cos(decl) * Math.cos(hourAngle);
			const zenith = Math.acos(clamp(cosZenith, -1, 1));
			return 90 - rad2deg(zenith);
		};
		const sunriseSunsetUTC = (lat, lon, date) => {
			const d = new Date(Date.UTC(date.getUTCFullYear(), date.getUTCMonth(), date.getUTCDate(), 12, 0, 0));
			const { eqTime, decl } = solarDeclEqTime(d);
			const latR = deg2rad(lat);
			const cosHa = (Math.cos(deg2rad(90.833)) / (Math.cos(latR) * Math.cos(decl))) - Math.tan(latR) * Math.tan(decl);
			if (cosHa < -1 || cosHa > 1) return null;
			const ha = rad2deg(Math.acos(cosHa));
			const noonMin = 720 - 4 * lon - eqTime;
			const sunriseMin = noonMin - 4 * ha;
			const sunsetMin = noonMin + 4 * ha;
			const toHHMM = (m) => {
				const x = ((m % 1440) + 1440) % 1440;
				const hh = Math.floor(x / 60);
				const mm = Math.floor(x % 60);
				return `${String(hh).padStart(2, "0")}:${String(mm).padStart(2, "0")}`;
			};
			return { sunrise: toHHMM(sunriseMin), sunset: toHHMM(sunsetMin), noon: toHHMM(noonMin) };
		};
		const estimatePassDuration = (maxElDeg, periodMin) => {
			const T = periodMin * 60;
			const mu = 3.986004418e14;
			const re = earthR * 1000;
			const a = Math.cbrt(mu * (T / (2 * Math.PI)) ** 2);
			const h = Math.max(100000, a - re);
			const q = re / (re + h);
			const alpha = Math.acos(clamp(q, -1, 1));
			const eMax = deg2rad(clamp(maxElDeg, 0.5, 89.9));
			const elev = (psi) => Math.atan2(Math.cos(psi) - q, Math.sin(psi));
			let lo = 0;
			let hi = alpha;
			for (let i = 0; i < 40; i += 1) {
				const mid = (lo + hi) / 2;
				if (elev(mid) > eMax) lo = mid;
				else hi = mid;
			}
			const psi0 = (lo + hi) / 2;
			const omega = 2 * Math.PI / T;
			const half = Math.sqrt(Math.max(0, alpha * alpha - psi0 * psi0)) / omega;
			return 2 * half / 60;
		};
		const latLonToGrid = (lat, lon) => {
			if (!(lat >= -90 && lat <= 90 && lon >= -180 && lon <= 180)) return null;
			const A = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
			const aLon = lon + 180;
			const aLat = lat + 90;
			const fLon = Math.floor(aLon / 20);
			const fLat = Math.floor(aLat / 10);
			const sLon = Math.floor((aLon % 20) / 2);
			const sLat = Math.floor(aLat % 10);
			const ssLon = Math.floor((((aLon % 2) * 60) / 5));
			const ssLat = Math.floor((((aLat % 1) * 60) / 2.5));
			return `${A[fLon]}${A[fLat]}${sLon}${sLat}${A[ssLon].toLowerCase()}${A[ssLat].toLowerCase()}`;
		};
		const gridToLatLon = (grid) => {
			const clean = String(grid || "").trim();
			if (clean.length < 4) return null;
			const g = clean.toUpperCase();
			const A = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
			const fLon = A.indexOf(g[0]);
			const fLat = A.indexOf(g[1]);
			const sLon = Number(g[2]);
			const sLat = Number(g[3]);
			if (fLon < 0 || fLat < 0 || !Number.isFinite(sLon) || !Number.isFinite(sLat)) return null;
			let lon = fLon * 20 + sLon * 2;
			let lat = fLat * 10 + sLat;
			let lonStep = 2;
			let latStep = 1;
			if (g.length >= 6) {
				const ssLon = A.indexOf(g[4]);
				const ssLat = A.indexOf(g[5]);
				if (ssLon >= 0 && ssLat >= 0) {
					lon += ssLon * (2 / 24);
					lat += ssLat * (1 / 24);
					lonStep = 2 / 24;
					latStep = 1 / 24;
				}
			}
			return {
				lat: lat - 90 + latStep / 2,
				lon: lon - 180 + lonStep / 2,
			};
		};

		const compute = () => {
			try {
				switch (formula) {
					case "swr-reflected": {
						const swr = n("swr");
						const fwdW = n("fwdW");
						if (!(swr >= 1) || !(fwdW > 0)) return setResult("SWR en az 1, ileri guc 0'dan buyuk olmali.");
						const gamma = (swr - 1) / (swr + 1);
						const reflectedPct = gamma * gamma * 100;
						const reflectedW = fwdW * reflectedPct / 100;
						const rl = -20 * Math.log10(gamma || 1e-9);
						const mismatchLoss = -10 * Math.log10(1 - gamma * gamma);
						return setResult(`|Gamma| ${fmt(gamma, 4)} | Yansiyan ${fmt(reflectedW, 2)} W (%${fmt(reflectedPct, 2)}) | Return loss ${fmt(rl, 2)} dB | Mismatch loss ${fmt(mismatchLoss, 2)} dB`);
					}
					case "returnloss-swr": {
						const mode = t("mode");
						const swr = n("swr");
						const rl = n("rl");
						if (mode === "swr-to-rl") {
							if (!(swr >= 1)) return setResult("SWR en az 1 olmali.");
							const gamma = (swr - 1) / (swr + 1);
							const resultRl = -20 * Math.log10(gamma || 1e-9);
							setField("rl", fmt(resultRl, 2));
							return setResult(`SWR ${fmt(swr, 3)} icin Return loss: ${fmt(resultRl, 2)} dB`);
						}
						if (mode === "rl-to-swr") {
							if (!(rl > 0)) return setResult("Return loss 0'dan buyuk olmali.");
							const gamma = Math.pow(10, -rl / 20);
							const resultSwr = (1 + gamma) / (1 - gamma);
							setField("swr", fmt(resultSwr, 3));
							return setResult(`Return loss ${fmt(rl, 2)} dB icin SWR: ${fmt(resultSwr, 3)}`);
						}
						return setResult("Donusum modunu secin.");
					}
					case "dbi-dbd": {
						const mode = t("mode");
						const dbi = n("dbi");
						const dbd = n("dbd");
						if (mode === "dbi-to-dbd") {
							if (!Number.isFinite(dbi)) return setResult("dBi degeri girin.");
							const out = dbi - 2.15;
							setField("dbd", fmt(out, 2));
							return setResult(`${fmt(dbi, 2)} dBi = ${fmt(out, 2)} dBd`);
						}
						if (mode === "dbd-to-dbi") {
							if (!Number.isFinite(dbd)) return setResult("dBd degeri girin.");
							const out = dbd + 2.15;
							setField("dbi", fmt(out, 2));
							return setResult(`${fmt(dbd, 2)} dBd = ${fmt(out, 2)} dBi`);
						}
						return setResult("Donusum modunu secin.");
					}
					case "fspl": {
						const f = n("freqMHz");
						const d = n("distanceKm");
						if (!(f > 0) || !(d > 0)) return setResult("Frekans ve mesafe 0'dan buyuk olmali.");
						return setResult(`FSPL: ${fmt(fsplDb(f, d), 2)} dB`);
					}
					case "link-budget": {
						const f = n("freqMHz");
						const d = n("distanceKm");
						const txW = n("txW");
						const txGain = n("txGain");
						const rxGain = n("rxGain");
						const lineLoss = n("lineLoss");
						const extraLoss = n("extraLoss");
						const rxSens = n("rxSens");
						if (!(f > 0) || !(d > 0) || !(txW > 0)) return setResult("Frekans, mesafe ve TX gucu gecerli olmali.");
						const path = fsplDb(f, d);
						const txDbm = wToDbm(txW);
						const rxDbm = txDbm + txGain + rxGain - lineLoss - extraLoss - path;
						const margin = Number.isFinite(rxSens) ? rxDbm - rxSens : NaN;
						return setResult(`FSPL ${fmt(path, 2)} dB | Rx ${fmt(rxDbm, 2)} dBm (${fmt(dbmToW(rxDbm) * 1000, 4)} mW) | Margin ${fmt(margin, 2)} dB`);
					}
					case "fresnel": {
						const d1 = n("d1Km");
						const d2 = n("d2Km");
						const f = n("freqGHz");
						const zone = n("zone");
						if (!(d1 > 0) || !(d2 > 0) || !(f > 0) || !(zone >= 1)) return setResult("Tum alanlar pozitif olmali.");
						const r = 17.32 * Math.sqrt((zone * d1 * d2) / (f * (d1 + d2)));
						return setResult(`${fmt(zone, 0)}. Fresnel yaricapi: ${fmt(r, 2)} m | %60 aciklik hedefi: ${fmt(r * 0.6, 2)} m`);
					}
					case "radio-horizon": {
						const h1 = n("h1");
						const h2 = n("h2");
						const k = n("k");
						if (!(h1 > 0) || !(h2 > 0) || !(k > 0)) return setResult("Yukseklikler ve K-faktor gecerli olmali.");
						const d = 3.57 * Math.sqrt(k / 1.33) * (Math.sqrt(h1) + Math.sqrt(h2));
						return setResult(`Teorik LOS menzili: ${fmt(d, 2)} km`);
					}
					case "repeater-coverage": {
						const hr = n("repeaterH");
						const hu = n("userH");
						const factor = n("envFactor");
						if (!(hr > 0) || !(hu > 0) || !(factor > 0)) return setResult("Tum degerler pozitif olmali.");
						const los = 3.57 * (Math.sqrt(hr) + Math.sqrt(hu));
						const est = los * factor;
