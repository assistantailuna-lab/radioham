const popularCodeSet = new Set(popularQCodes.map((item) => item.code));
const remainingQCodes = allQCodes.filter((item) => !popularCodeSet.has(item.code));
---

<Layout lang="tr" title="Q Kodlar | RadioHam" description="En çok kullanılanlar başta olmak üzere Q kodlar ve anlamları.">
	<SiteNav lang="tr" current="glossary" />

	<section class="page-hero">
		<div class="container">
			<h1>Q Kodlar</h1>
			<p>En çok kullanılan Q kodlar başta olacak şekilde tüm listeyi inceleyebilirsin.</p>
		</div>
	</section>

	<section class="section">
		<div class="container">
			<div class="outline-section q-section">
				<div class="back-row">
					<a href="/sozluk">Sözlüğe Dön</a>
				</div>

				<h2>En Çok Kullanılan Q Kodlar</h2>
				<div class="table-wrap">
					<table>
						<thead>
							<tr>
								<th>Kod</th>
								<th>Anlamı</th>
							</tr>
						</thead>
						<tbody>
							{
								popularQCodes.map((row) => (
									<tr>
										<td>{row.code}</td>
										<td>{row.meaning}</td>
									</tr>
								))
							}
						</tbody>
					</table>
				</div>

				<h2 class="rest-title">Q Kodların Tam Listesi</h2>
				<div class="table-wrap">
					<table>
						<thead>
							<tr>
								<th>Kod</th>
								<th>Anlamı</th>
							</tr>
						</thead>
						<tbody>
							{
								remainingQCodes.map((row) => (
									<tr>
										<td>{row.code}</td>
										<td>{row.meaning}</td>
									</tr>
								))
							}
						</tbody>
					</table>
				</div>
			</div>
		</div>
	</section>

	<SiteFooter lang="tr" />
</Layout>

<style>
	.q-section {
		margin-top: 22px;
	}

	.back-row {
		margin-bottom: 10px;
	}

	.back-row a {
		color: #165da8;
		font: 700 13px/1 "Exo 2", sans-serif;
		text-decoration: none;
	}

	.back-row a:hover {
		text-decoration: underline;
	}

	h2 {
		margin: 8px 0 10px;
		font: 700 24px/1.2 "Exo 2", sans-serif;
		color: #123b6c;
	}

	.rest-title {
		margin-top: 18px;
	}

	.table-wrap {
		overflow-x: auto;
	}

	table {
		width: 100%;
		border-collapse: collapse;
		font-size: 14px;
	}

	th,
	td {
		border: 1px solid #d7e2ee;
		padding: 10px 12px;
		text-align: left;
		vertical-align: top;
	}

	th {
		background: #f2f7fd;
		color: #0e3f73;
		font-weight: 700;
	}

	td:first-child {
		font-weight: 700;
		color: #184b81;
		white-space: nowrap;
	}
</style>


