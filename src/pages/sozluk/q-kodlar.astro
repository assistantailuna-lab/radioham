	{ code: "QUK", meaning: "Bulundugunuz yerde deniz durumu nasildir?" },
	{ code: "QUL", meaning: "Bulundugunuz yerde dalga/swell durumu?" },
	{ code: "QUM", meaning: "Normal calismaya geri donelim mi?" },
	{ code: "QUN", meaning: "Yakin gemiler konum/rota/hiz bilgilerini verir mi?" },
	{ code: "QUO", meaning: "Ucak/gemi/kurtarma araci aramasi yapilmali mi?" },
	{ code: "QUP", meaning: "Konumunuzu isik/duman/isaret fisegi ile belirtin." },
	{ code: "QUQ", meaning: "Bulut ustune projektor tutup yonlendirme yapin." },
	{ code: "QUR", meaning: "Hayatta kalanlarin durumunu/ulasilma bilgisini bildirin." },
	{ code: "QUS", meaning: "Kazazede/enkaz gordunuz mu?" },
	{ code: "QUT", meaning: "Olay yeri isaretlendi mi?" },
	{ code: "QUU", meaning: "Ana gemi/ucagi benim konumuma yonlendirin." },
	{ code: "QUW", meaning: "Belirlenen arama bolgesinde misiniz?" },
	{ code: "QUX", meaning: "Seyir veya firtina uyari mesaji var mi?" },
	{ code: "QUY", meaning: "Kurtarma aracinin konumu isaretlendi mi?" },
	{ code: "QUZ", meaning: "Kisitli calismayi sonlandirip normale donun." },
