	},
	{
		name: "Step Freq",
		desc: "VFO modunda frekans adım miktarını belirler. Kanal modunda değişmez.",
		tips: ["Genel kullanımda 12.5 kHz", "Bilmiyorsan 12.5 kHz ile başla"],
	},
	{
		name: "VOX Level",
		desc: "PTT basmadan sesle otomatik yayına geçiş hassasiyetini ayarlar.",
		tips: ["El telsizinde çoğu kullanıcı için Off", "Eller serbest kullanımda 1-2 ile test et"],
	},
	{
		name: "VOX Delay",
		desc: "Konuşma bittikten sonra yayının kapanma gecikmesini belirler.",
		tips: ["Normalde 1 sn", "Duraklamalı konuşmada 2 sn"],
	},
	{
		name: "TOT",
		desc: "Uzun basışta yayın kilitlenmesini önlemek için maksimum TX süresi koyar.",
