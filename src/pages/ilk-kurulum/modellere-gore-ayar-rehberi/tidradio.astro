		name: "Factory Reset",
		desc: "VFO, CHL veya FULL sıfırlama seçenekleri.",
		tips: ["Gerekmedikçe kullanma", "FULL seçeneğinde dikkatli ol"],
	},
	{ name: "Breath Led", desc: "Beklemede LED yanıp sönme davranışı.", tips: ["Pil için düşük veya kapalı mantıklı"] },
	{
		name: "MIC GAIN",
		desc: "Mikrofon kazancı.",
		tips: ["Normal konuşmada 4-6", "Ses kısık gidiyorsa 6-7", "Distorsiyonda düşür"],
	},
	{ name: "DTMF Speed", desc: "DTMF gönderim hızı.", tips: ["Varsayılan 110 ms bırak"] },
	{ name: "DCD", desc: "DTMF sinyallemeyi aç/kapat.", tips: ["Kullanmayacaksan Off"] },
	{ name: "D-HOLD", desc: "DTMF otomatik sıfırlama süresi.", tips: ["10-15 sn"] },
	{ name: "D-RSP", desc: "DTMF çözümleme sonrası tepki tipi.", tips: ["DTMF kullanmıyorsan NULL"] },
